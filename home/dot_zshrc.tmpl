FPATH="${HOMEBREW_PREFIX}/share/zsh-completions:${HOMEBREW_PREFIX}/share/zsh/site-functions:${FPATH}"
autoload -Uz compinit && compinit

HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE

eval "$(mise activate zsh)"
eval "$(zoxide init zsh --cmd cd)"
eval "$(starship init zsh)"
source <(fzf --zsh)

export EDITOR="zed --wait"
export MANPAGER="sh -c 'col -bx | bat -l man -p'"
export MANROFFOPT="-c"

export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --exclude .git"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type d --hidden --follow --exclude .git"
export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border"

_fzf_preview="if [ -d {} ]; then eza --tree --color=always --icons=always --level=2 {} | head -200; else bat --color=always --style=numbers --line-range :300 {}; fi"
export FZF_CTRL_T_OPTS="--preview '$_fzf_preview' --bind 'ctrl-/:toggle-preview'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always --icons=always --level=2 {} | head -200'"

alias ls="eza --icons=auto --group-directories-first"
alias la="eza -a --icons=auto --group-directories-first"
alias ll="eza -l --icons=auto --git --group-directories-first"
alias lla="eza -la --icons=auto --git --group-directories-first"
alias lt="eza --tree --icons=auto --level=2"
alias cat="bat --paging=never"

source "${HOMEBREW_PREFIX}/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "${HOMEBREW_PREFIX}/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
